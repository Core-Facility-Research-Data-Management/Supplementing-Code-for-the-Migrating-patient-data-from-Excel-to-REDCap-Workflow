    family-names: Rabenstein
    affiliation: University of Bonn, University Hospital Bonn, Core Facility Research Data Management, IDM
    orcid: "https://orcid.org/0000-0001-7712-224X"
keywords:
  - REDCap
  - R
  - Python
  - Jupyter Notebook
  - Data base
  - Data Migration
  - Clinical Data
